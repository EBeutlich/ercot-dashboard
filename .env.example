# ERCOT Dashboard Configuration
# 
# RECOMMENDED: Use Lambda backend (secure, credentials stored in AWS SSM)
# After deploying the Lambda backend, set your API Gateway URL here:
VITE_ERCOT_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod/api

# ALTERNATIVE: Direct API access (credentials exposed in browser - NOT recommended)
# Only use if you cannot deploy the Lambda backend
# Get credentials from https://apiexplorer.ercot.com after registration
#
# VITE_ERCOT_SUBSCRIPTION_KEY=your-subscription-key-here
# VITE_ERCOT_USERNAME=your-email@example.com
# VITE_ERCOT_PASSWORD=your-password-here
